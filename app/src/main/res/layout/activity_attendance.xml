<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Title Bar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Attendance Report"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="15dp"
        android:background="#000080" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Subject 1 Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="#1A1A1A"
                android:orientation="vertical"
                android:padding="20dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvSubject1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject 1"
                    android:textColor="#007bff"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvTotal1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Classes: 65"
                    android:textSize="14sp"
                    android:textColor="#BBBBBB"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txtPercentage1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#007bff"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvStats1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Present: 0 | Absent: 65"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- Subject 2 Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="#1A1A1A"
                android:orientation="vertical"
                android:padding="20dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvSubject2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject 2"
                    android:textColor="#007bff"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvTotal2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Classes: 65"
                    android:textSize="14sp"
                    android:textColor="#BBBBBB"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txtPercentage2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#007bff"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvStats2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Present: 0 | Absent: 65"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

            <!-- Subject 3 Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="20dp"
                android:background="#1A1A1A"
                android:orientation="vertical"
                android:padding="20dp"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/tvSubject3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject 3"
                    android:textColor="#007bff"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvTotal3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Classes: 65"
                    android:textSize="14sp"
                    android:textColor="#BBBBBB"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/txtPercentage3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#007bff"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:id="@+id/tvStats3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Present: 0 | Absent: 65"
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_marginTop="5dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
